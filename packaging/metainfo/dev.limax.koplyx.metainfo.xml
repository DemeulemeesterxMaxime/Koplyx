<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.limax.koplyx</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Koplyx</name>
  <summary>Local encrypted clipboard history</summary>
  <developer id="dev.limax">
    <name>Limax</name>
  </developer>
  <description>
    <p>Koplyx keeps a local encrypted history of text and image clipboard entries so users can quickly recover previous copies.</p>
    <p>It provides search, pinned text, quick restore, optional X11 auto-paste, and a system tray indicator.</p>
    <p>This app currently targets Linux desktop environments with X11 support. Wayland behavior can vary by compositor.</p>
  </description>
  <launchable type="desktop-id">dev.limax.koplyx.desktop</launchable>
  <provides>
    <binary>koplyx</binary>
  </provides>
  <content_rating type="oars-1.1" />
