      <description>
        <p>Add Snapcraft and Flatpak packaging metadata.</p>
      </description>
    </release>
    <release version="0.2.0" date="2026-05-16">
      <description>
        <p>Public release hardening with Secret Service key storage and HTML documentation.</p>
      </description>
    </release>
  </releases>
  <url type="homepage">https://github.com/DemeulemeesterxMaxime/Koplyx</url>
